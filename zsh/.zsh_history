: 1775607671:0;zshrc
: 1775607767:0;cat << 'EOF' >> ~/.config/zsh/.zshrc\
\
# XDG Base Directory Overrides\
export ANDROID_USER_HOME="$HOME/.local/share/android"\
export MAXIMA_USERDIR="$HOME/.config/maxima"\
export TEXMFHOME="$HOME/.local/share/texmf"\
export R_HISTFILE="$HOME/.local/state/R/history"\
export XAUTHORITY="$XDG_RUNTIME_DIR/Xauthority"\
EOF
: 1775607890:0;echo 'set viminfo+=n~/.cache/vim/viminfo' >> ~/.config/vim/vimrc\
mv ~/.viminfo ~/.cache/vim/viminfo 2>/dev/null || true
: 1775607908:0;ls
: 1775607911:0;ls -a
: 1775607935:0;echo 'alias startx="startx ~/.config/X11/xinitrc"' >> ~/.config/zsh/.zshrc
: 1775607967:0;rm -f ~/.bash_history ~/.bash_logout ~/.bash_profile ~/.bashrc ~/.shell.pre-oh-my-zsh ~/home_dir_clutter ~/.fehbg
: 1775607977:0;ls
: 1775607980:0;ls -a
: 1775608169:0;# Move the existing program directories into their new XDG homes\
cp -r ~/.android/. ~/.local/share/android/ 2>/dev/null && rm -rf ~/.android\
cp -r ~/.maxima/. ~/.config/maxima/ 2>/dev/null && rm -rf ~/.maxima\
cp -r ~/texmf/. ~/.local/share/texmf/ 2>/dev/null && rm -rf ~/texmf\
\
# Move R history and data\
mv ~/.Rhistory ~/.local/state/R/history 2>/dev/null\
mv ~/.RData ~/.local/state/R/ 2>/dev/null\
\
# Move the Zsh files that respawned or were added\
mv ~/.zsh_history ~/.config/zsh/ 2>/dev/null\
mv ~/.zprofile ~/.config/zsh/ 2>/dev/null\
\
# Delete Xauthority (it will safely regenerate in $XDG_RUNTIME_DIR on your next startx)\
rm -f ~/.Xauthority
